generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// ----------------------
/// MODELO DE USUÁRIOS
/// ----------------------

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  avatarUrl String?
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações inversas
  chamadosAdmin   Chamado[] @relation("ChamadosAdmin")
  chamadosCliente Chamado[] @relation("ChamadosCliente")
  chamadosTecnico Chamado[] @relation("ChamadosTecnico")

  services         Service[]         @relation("ServicesByAdmin")
  disponibilidades Disponibilidade[] @relation("DisponibilidadesDoTecnico")
}

enum Role {
  ADMIN
  TECNICO
  CLIENTE
}

/// ----------------------
/// MODELOS DE NEGÓCIO
/// ----------------------

model Service {
  id        String   @id @default(uuid())
  name      String
  price     Float
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminId  String
  admin    User             @relation("ServicesByAdmin", fields: [adminId], references: [id])
  chamados ChamadoService[]
}

model Chamado {
  id        String   @id @default(uuid())
  status    Status   @default(ABERTO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminId String
  admin   User   @relation("ChamadosAdmin", fields: [adminId], references: [id])

  clienteId String
  cliente   User   @relation("ChamadosCliente", fields: [clienteId], references: [id], onDelete: Cascade)

  tecnicoId String
  tecnico   User   @relation("ChamadosTecnico", fields: [tecnicoId], references: [id])

  services   ChamadoService[]
  totalPrice Float?
}

model ChamadoService {
  id        String @id @default(uuid())
  chamadoId String
  serviceId String

  chamado Chamado @relation(fields: [chamadoId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
}

/// ----------------------
/// MODELOS AUXILIARES
/// ----------------------

model Disponibilidade {
  id        String @id @default(uuid())
  tecnicoId String
  horario   String

  tecnico User @relation("DisponibilidadesDoTecnico", fields: [tecnicoId], references: [id])
}

enum Status {
  ABERTO
  EM_ATENDIMENTO
  ENCERRADO
}
